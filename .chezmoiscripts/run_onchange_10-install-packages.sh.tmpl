#!/usr/bin/env bash
set -euo pipefail
if [[ "${CHEZMOI_INSTALL_PACKAGES:-0}" == "1" ]]; then
  "{{ .chezmoi.sourceDir }}/scripts/install-system-packages.sh" --tier "${BOOTSTRAP_TIER:-minimal}"
  "{{ .chezmoi.sourceDir }}/scripts/install-homebrew.sh"
  "{{ .chezmoi.sourceDir }}/scripts/install-packages.sh" --tier "${BOOTSTRAP_TIER:-minimal}"
else
  echo "Skipping package install during chezmoi apply; run bootstrap.sh or set CHEZMOI_INSTALL_PACKAGES=1."
fi
