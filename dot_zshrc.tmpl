# Chezmoi-managed zshrc
# Machine: ipsec-10-2-64-173 | OS: darwin
# vim: set ft=zsh:

# Path configuration
export PATH=$HOME/bin:/usr/local/bin:$PATH

# Oh-My-Zsh installation
export ZSH="$HOME/.oh-my-zsh"

# Theme: Pure prompt
ZSH_THEME=""
fpath+=("$(brew --prefix)/share/zsh/site-functions")
fpath+=($HOME/.oh-my-zsh/custom/themes/pure)
autoload -U promptinit; promptinit

# Git stash status in prompt
zstyle :prompt:pure:git:stash show yes
prompt pure

# History Configuration
HIST_STAMPS="mm/dd/yyyy"
HISTSIZE=100000000
SAVEHIST=100000000
HISTFILE=~/.zsh_history
setopt appendhistory     # Append history to the history file (no overwriting)
setopt sharehistory      # Share history across terminals
setopt incappendhistory  # Immediately append to the history file

# Plugins
plugins=(
    git
    brew
    common-aliases
    node
    npm
    sudo
    z
    colored-man-pages
    colorize
    cp
    zsh-syntax-highlighting
    zsh-autosuggestions
    macos
)

source $ZSH/oh-my-zsh.sh

# GPG TTY
export GPG_TTY=$(tty)

# Personal configuration
[ -f "$HOME/.zshrc.alan" ] && source "$HOME/.zshrc.alan"

# Local bin
[ -f "$HOME/.local/bin/env" ] && source "$HOME/.local/bin/env"
# OpenCode
export PATH="$HOME/.opencode/bin:$PATH"

# Antigravity
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# Bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$HOME/.oh-my-zsh/completions/_bun" ] && source "$HOME/.oh-my-zsh/completions/_bun"

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# wrk shell integration
#source /Users/alansynn/.local/bin/wrk shell zsh
function wrk() {
    local target
    target=$(/Users/alansynn/.local/bin/wrk "$@")
    if [ -d "$target" ]; then
        cd "$target"
    elif [ -n "$target" ]; then
        echo "$target"
    fi
}


# The next line updates PATH for the Google Cloud SDK.
if [ -f '/Users/alansynn/Downloads/google-cloud-sdk/path.zsh.inc' ]; then . '/Users/alansynn/Downloads/google-cloud-sdk/path.zsh.inc'; fi

# The next line enables shell command completion for gcloud.
if [ -f '/Users/alansynn/Downloads/google-cloud-sdk/completion.zsh.inc' ]; then . '/Users/alansynn/Downloads/google-cloud-sdk/completion.zsh.inc'; fi
