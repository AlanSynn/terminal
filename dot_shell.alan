########################################################
# Docker
########################################################

dps() {
    docker ps --format "table {{.ID}}\t{{.Names}}\t{{.Status}}\t{{.Ports}}"
}

dpsa() {
    docker ps -a --format "table {{.ID}}\t{{.Names}}\t{{.Status}}\t{{.Ports}}"
}

########################################################
# Python
########################################################

vcreate() {
    python -m venv .venv
}

vactivate() {
    if [ -f .venv/bin/activate ]; then
        . .venv/bin/activate
    else
        printf "${ANSI_RED}Virtual environment not found${ANSI_RESET}\n"
        return 1
    fi
}

vdeactivate() {
    # Check if venv is activated
    if [ -n "$VIRTUAL_ENV" ]; then
        printf "${ANSI_RED}Venv is activated${ANSI_RESET}\n"
        deactivate
    fi
    # Check if conda is activated
    if [ -n "$CONDA_PREFIX" ]; then
        printf "${ANSI_RED}Conda is activated${ANSI_RESET}\n"
        conda deactivate
    fi
}

########################################################
# Python
########################################################

# Remove all __pycache__ directories
pyclean() {
    find . -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null
    find . -type f -name "*.pyc" -exec rm -f {} + 2>/dev/null
    find . -type f -name "*.pyo" -exec rm -f {} + 2>/dev/null
    find . -type f -name "*.pyd" -exec rm -f {} + 2>/dev/null
}
